# ===========================================================================
# NiteBuddy — Environment Variables
# Copy this file to .env and fill in your values
# ===========================================================================

# ── Database ────────────────────────────────────────────────────────────────
POSTGRES_USER=nitebuddy
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=nitebuddy_db
DATABASE_URL=postgresql+asyncpg://nitebuddy:change_me_strong_password@localhost:5432/nitebuddy_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Qdrant Vector DB ─────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ── Security ──────────────────────────────────────────────────────────────────
SECRET_KEY=generate_a_random_secret_key_here_min_32_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── AI Provider ───────────────────────────────────────────────────────────────
# Options: "ollama" | "openai" | "compatible"
AI_PROVIDER=ollama

# For Ollama (local, free)
OLLAMA_BASE_URL=http://localhost:11434
AI_MODEL=qwen3:8b

# For OpenAI API (cloud, paid) — leave blank if using Ollama
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# For OpenAI-compatible APIs (e.g. LM Studio, vLLM)
COMPATIBLE_API_URL=
COMPATIBLE_API_KEY=

# ── Embeddings ────────────────────────────────────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Google OAuth (Phase 2) ────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# ── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=NiteBuddy

# ── Email (Phase 2 — notifications) ──────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@nitebuddy.ai

# ── Sentry (optional monitoring) ──────────────────────────────────────────────
SENTRY_DSN=

# ── Safety Engine ─────────────────────────────────────────────────────────────
CRISIS_KEYWORDS=suicide,self-harm,kill myself,end my life,hurt myself
CRISIS_RESPONSE_ENABLED=true
